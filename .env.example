# Provider credentials and hosts.
# For local providers you can use either the raw host or the /v1 endpoint.
# Example:
# OLLAMA_HOST=http://localhost:11434
# LLAMACPP_HOST=http://localhost:8080/v1
# MLX_HOST=http://localhost:8080

OPENROUTER_API_KEY=
OLLAMA_HOST=
LLAMACPP_HOST=
MLX_HOST=

# Comma-separated provider:model entries.
# Use the provider keys exactly as: openrouter, ollama, llamacpp, mlx
# Example:
# LLM_MODELS=openrouter:openai/gpt-4.1,ollama:qwen3.5:4b,llamacpp:local-model,mlx:Qwen/Qwen3.5-9B
# LLM_MODELS_2=ollama:my-distilled-model
LLM_MODELS=
LLM_MODELS_2=
